# Copy this file to ".env" in this same folder, then fill in your real
# values. The actual .env file is git-ignored and never committed —
# credentials should never be hardcoded in server.js.

PORT=5000

# The email account that SENDS the message. For Gmail, EMAIL_PASS must
# be a 16-character "App Password" (Google Account → Security → 2-Step
# Verification → App passwords), not your normal login password.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-16-character-app-password

# 👉 The address where YOU want to receive contact form messages.
# Can be the same as EMAIL_USER, or a different inbox entirely.
EMAIL_TO=your-real-email@example.com
